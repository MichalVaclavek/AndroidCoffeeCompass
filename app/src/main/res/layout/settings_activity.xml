<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_settings_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="8dp"
    tools:context=".widgets.WidgetConfigurationActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/linearLayout2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:isScrollContainer="false"
                android:orientation="vertical"
                tools:layout_editor_absoluteX="8dp">


                <TextView
                    android:id="@+id/tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="Káva s sebou - nastavení"
                    android:textAppearance="@style/TextAppearance.AppCompat.Large" />

                <FrameLayout
                    android:id="@+id/settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp">

                    <include
                        android:id="@+id/widget_settings_container"
                        layout="@layout/main_app_widget"
                        android:layout_width="match_parent"
                        android:layout_height="90dp" />

                </FrameLayout>

                <RadioGroup
                    android:id="@+id/widget_search_distance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/title_search_distance_widget"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"
                        android:text="Vzdálenost vyhledávání v nástroji"
                        android:textAppearance="@style/TextAppearance.AppCompat.Large"
                        android:textSize="18sp" />

                    <RadioButton
                        android:id="@+id/widget_dist_100"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:onClick="onChooseSearchDistance"
                        android:text="100 m" />

                    <RadioButton
                        android:id="@+id/widget_dist_200"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:onClick="onChooseSearchDistance"
                        android:text="200 m" />

                    <RadioButton
                        android:id="@+id/widget_dist_500"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:onClick="onChooseSearchDistance"
                        android:text="500 m" />

                    <RadioButton
                        android:id="@+id/widget_dist_1000"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:onClick="onChooseSearchDistance"
                        android:text="1000 m" />

                    <RadioButton
                        android:id="@+id/widget_dist_2000"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:onClick="onChooseSearchDistance"
                        android:text="2000 m" />
                </RadioGroup>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="10">

                    <RadioGroup
                        android:id="@+id/widget_backround_color"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_weight="5"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/title_backround_color"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="8dp"
                            android:text="Barva pozadí"
                            android:textAppearance="@style/TextAppearance.AppCompat.Large"
                            android:textSize="18sp" />

                        <RadioButton
                            android:id="@+id/red_backround"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:onClick="onChooseBackroundColor"
                            android:text="Red" />

                        <RadioButton
                            android:id="@+id/blue_backround"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:onClick="onChooseBackroundColor"
                            android:text="Blue" />

                        <RadioButton
                            android:id="@+id/green_backround"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:onClick="onChooseBackroundColor"
                            android:text="Green" />

                        <RadioButton
                            android:id="@+id/black_backround"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:onClick="onChooseBackroundColor"
                            android:text="Black" />
                    </RadioGroup>

                    <RadioGroup
                        android:id="@+id/widget_frame_color"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_weight="5"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/title_frame_color"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="8dp"
                            android:text="Barva rámečku"
                            android:textAppearance="@style/TextAppearance.AppCompat.Large"
                            android:textSize="18sp" />

                        <RadioButton
                            android:id="@+id/red_frame"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:onClick="onChooseFrameColor"
                            android:text="Red" />

                        <RadioButton
                            android:id="@+id/blue_frame"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:onClick="onChooseFrameColor"
                            android:text="Blue" />

                        <RadioButton
                            android:id="@+id/green_frame"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:onClick="onChooseFrameColor"
                            android:text="Green" />

                        <RadioButton
                            android:id="@+id/black_frame"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:onClick="onChooseFrameColor"
                            android:text="Black" />
                    </RadioGroup>
                </LinearLayout>

                <TextView
                    android:id="@+id/widget_backround_opacity_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Průhlednost pozadí"
                    android:textAppearance="@style/TextAppearance.AppCompat.Large"
                    android:textSize="18sp" />

                <SeekBar
                    android:id="@+id/widget_background_opacity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:max="255"
                    android:min="0" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:paddingTop="20dp">

                    <Button
                        android:id="@+id/close_settings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:onClick="closeSettings"
                        android:text="Zavřít" />
                </FrameLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>