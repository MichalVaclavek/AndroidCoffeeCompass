<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <ImageView
        android:id="@+id/manage_image_view"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@android:color/darker_gray"
        android:scaleType="centerCrop" />

    <!-- Delete button overlay, top-right corner -->
    <ImageView
        android:id="@+id/manage_image_delete_button"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="top|end"
        android:layout_margin="4dp"
        android:background="@drawable/image_pager_arrow_background"
        android:contentDescription="@string/manage_images_delete_image"
        android:padding="4dp"
        android:scaleType="centerInside"
        android:src="@android:drawable/ic_menu_close_clear_cancel" />

</FrameLayout>
