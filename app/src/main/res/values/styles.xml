<resources>

    <style name="Theme.CoffeeCompass" parent="Theme.MaterialComponents.Light.NoActionBar.Bridge">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:enforceNavigationBarContrast">false</item>
    </style>

    <!-- Base application theme. -->
     <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
         <!--<style name="AppTheme" parent="@style/Theme.MaterialComponents.Light.NoActionBar.Bridge">  -->
             <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.CoffeeCompass">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="AppTheme.RoundedCornerKafeButton" parent="Widget.AppCompat.Button.Colored">
        <item name="android:background">@drawable/button_kafe_background_selector</item>
    </style>

    <style name="AppTheme.RoundedCornerEspressoButton" parent="Widget.AppCompat.Button.Colored">
        <item name="android:background">@drawable/button_espresso_background_selector</item>
    </style>

    <style name="NoActionBar" parent="Theme.CoffeeCompass">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="SelectedChipCustomStyle" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:backgroundTint">@color/background_color_chip_state_list</item>
        <item name="android:textColor">@color/text_color_chip_state_list</item>
    </style>

    <!-- <style name="MyCoffeeSiteInputHintAppearance" parent="ThemeOverlay.AppCompat.Light"> -->
    <style name="SiteInput.HintAppearance" parent="ThemeOverlay.AppCompat.Light">
            <!-- Hint color and label color in FALSE state -->
        <!-- <item name="android:textColorHint">@color/colorPrimary2</item> -->
        <item name="hintTextColor">@color/colorPrimary2</item>

        <item name="colorPrimary">@color/colorPrimary2</item>
        <item name="colorSecondary">@color/colorPrimary</item>

        <!-- Label color in TRUE state and bar color FALSE and TRUE State -->
        <item name="colorAccent">@color/colorPrimary2</item>
        <item name="colorControlNormal">@color/colorPrimary2</item>
        <item name="colorControlActivated">@color/colorPrimary2</item>


    </style>

    <style name="TimePickerDialogTheme" parent="Theme.AppCompat.Dialog">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="android:windowBackground">@color/colorPrimary2</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="Toolbar.TitleText" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textSize">24sp</item>
    </style>

    <style name="Toolbar.SubTitleText" parent="TextAppearance.Widget.AppCompat.Toolbar.Subtitle">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/activityBackround</item>
    </style>

    <!--    Switch Button on MyCoffeeSitesListActivity menu bar-->
    <style name="AppTheme.SwitchAB">
        <!-- colorPrimary is used for the default action bar background -->
        <item name="colorPrimary">@color/colorPrimary</item>

        <!-- colorPrimaryDark is used for the status bar -->
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>

        <!-- When switch ON -->
        <item name="colorAccent">@color/colorAccent</item>

        <!-- When switch ON ?? -->
        <item name="colorControlActivated">@color/colorAccent</item>

        <!-- When switch OFF -->
        <item name="colorSwitchThumbNormal">@color/site_status_dark_gray</item>

        <!-- You can also set colorControlNormal, colorControlActivated
             colorControlHighlight, and colorSwitchThumbNormal. -->

    </style>

</resources>
